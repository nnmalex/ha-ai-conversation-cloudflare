{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-ha-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-03",
  "compatibility_flags": ["nodejs_compat"],

  "durable_objects": {
    "bindings": [
      {
        "name": "HOME_ASSISTANT_AGENT",
        "class_name": "HomeAssistantAgent"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["HomeAssistantAgent"]
    }
  ],

  "ai": {
    "binding": "AI"
  },

  "vars": {
    "AI_MODEL": "@cf/zai-org/glm-4.7-flash"
  },

  "observability": {
    "enabled": true
  },

  // Wake the DO every 5 minutes to keep MCP connection + tools warm
  "triggers": {
    "crons": ["*/5 * * * *"]
  }
}
